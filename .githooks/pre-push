#!/bin/bash
set -e

remote="$1"

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$remote_ref" == "refs/heads/main" ]] || continue
  [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && continue

  CARGO_VER=$(sed -n 's/^version = "\(.*\)"/\1/p' Cargo.toml | head -1)

  LATEST_TAG=$(git ls-remote --tags "$remote" 'refs/tags/v[0-9]*.[0-9]*.[0-9]*' \
    | grep -v '\^{}' \
    | awk '{print $2}' \
    | sed 's|refs/tags/||' \
    | sort -V \
    | tail -1)

  if [[ -z "$LATEST_TAG" ]]; then
    NEW_VER="$CARGO_VER"
  else
    VER="${LATEST_TAG#v}"
    IFS='.' read -r MAJ MIN PAT <<< "$VER"
    IFS='.' read -r C_MAJ C_MIN C_PAT <<< "$CARGO_VER"
    if (( C_MAJ > MAJ )) || \
       (( C_MAJ == MAJ && C_MIN > MIN )) || \
       (( C_MAJ == MAJ && C_MIN == MIN && C_PAT > PAT )); then
      NEW_VER="$CARGO_VER"
    else
      NEW_VER="${MAJ}.${MIN}.$((PAT + 1))"
    fi
  fi

  [[ "$NEW_VER" == "$CARGO_VER" ]] && exit 0

  echo "Bumping version $CARGO_VER → $NEW_VER"
  sed -i "s/^version = \"[^\"]*\"/version = \"$NEW_VER\"/" Cargo.toml
  awk -v v="$NEW_VER" \
    '/^name = "gitreg"$/{found=1} found && /^version = /{sub(/"[^"]*"/, "\"" v "\""); found=0} {print}' \
    Cargo.lock > Cargo.lock.tmp && mv Cargo.lock.tmp Cargo.lock

  git add Cargo.toml Cargo.lock
  git commit --no-verify -m "chore: bump version to v$NEW_VER"

  echo ""
  echo "Version bumped to v$NEW_VER — run 'git push' again to push the bump commit."
  exit 1
done

exit 0
